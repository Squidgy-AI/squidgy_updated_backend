# .slugignore - Exclude files from Heroku slug to reduce size

# Archived directories (no longer in active codebase)
archive/

# Documentation files
*.md
README*
docs/
LICENSE

# Development files
.git/
.gitignore
.env*
.vscode/
.idea/
backend.log

# Test files
tests/
test_*.py
*_test.py

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Temporary files
*.tmp
*.temp
temp/

# Heavy packages
*.whl
*.tar.gz

# Screenshots and static assets not needed for production
static/screenshots/*
static/favicons/*

# Build artifacts
build/
dist/
*.egg-info/

# Virtual environments
venv/
env/
ENV/
virtual_back/

# Additional heavy requirements files (keep requirements.txt for Heroku)
requirements-prod.txt
requirements_free_embeddings.txt
requirements_heroku.txt

# Old config files
runtime_1.txt
.env.heroku